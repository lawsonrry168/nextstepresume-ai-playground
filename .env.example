# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APIFY_API_TOKEN: Optional — enables JobsDB HK search via Apify (https://apify.com/shahidirfan/jobsdb-scraper).
APIFY_API_TOKEN=""

# NSR_JOBSDB_SIMULATE: Return fixture JobsDB listings (default when APIFY_API_TOKEN is empty).
# NSR_JOBSDB_SIMULATE="1"

# NSR_QUOTA_STORE: memory (default) or redis for multi-instance quota persistence.
# NSR_QUOTA_STORE="memory"

# NSR_REDIS_URL: Redis connection string when NSR_QUOTA_STORE=redis.
# NSR_REDIS_URL="redis://127.0.0.1:6379"
# Start local Redis: npm run redis:start
# Run integration tests: npm run test:redis

# APP_URL: Public URL for OAuth callbacks and self-referential links.
APP_URL="MY_APP_URL"

# Market is fixed to Hong Kong (hk) in src/lib/market/config.ts for this deployment.
