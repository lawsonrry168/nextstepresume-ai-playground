# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APIFY_API_TOKEN: Optional — enables JobsDB HK search via Apify (https://apify.com/shahidirfan/jobsdb-scraper).
APIFY_API_TOKEN=""

# NSR_JOBSDB_SIMULATE: Return fixture JobsDB listings (default when APIFY_API_TOKEN is empty).
# NSR_JOBSDB_SIMULATE="1"

# NSR_QUOTA_STORE: memory (default) or redis for multi-instance quota persistence.
# NSR_QUOTA_STORE="memory"

# NSR_RATE_LIMIT_STORE: memory (default) or redis for distributed /api rate limiting.
# NSR_RATE_LIMIT_STORE="redis"

# NSR_RATE_LIMIT_MAX: Max /api requests per IP per minute (default 60). E2E sets 1000 locally.
# NSR_RATE_LIMIT_MAX="60"

# NSR_REDIS_URL: Redis connection string when NSR_QUOTA_STORE=redis or NSR_RATE_LIMIT_STORE=redis.
# NSR_REDIS_URL="redis://127.0.0.1:6379"
# Production: use a managed Redis (TLS) URL, e.g. rediss://:password@host:6379
# Set NSR_QUOTA_STORE=redis and/or NSR_RATE_LIMIT_STORE=redis on every app instance.

# NSR_REDIS_INTEGRATION_REQUIRED: Set to 1 in CI / local integration runs (npm run test:redis).
# NSR_REDIS_INTEGRATION_REQUIRED="1"

# REDIS_SERVER_PATH: Optional Windows path to redis-server.exe (npm run redis:start).
# REDIS_SERVER_PATH="C:\\path\\to\\redis-server.exe"

# Start local Redis: npm run redis:start
# Run integration tests: npm run test:redis

# APP_URL: Public URL for OAuth callbacks, Stripe redirect URLs, and self-referential links.
APP_URL="https://your-domain.example"

# NSR_APP_MODE: playground (default, demo billing) or production (Stripe-authoritative plans).
# NSR_APP_MODE="playground"

# Stripe (required when NSR_APP_MODE=production)
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_PRO_MONTHLY="price_..."
# STRIPE_PRICE_MAX_MONTHLY="price_..."
# Webhook endpoint: POST {APP_URL}/api/billing/webhook
# Local testing: stripe listen --forward-to localhost:3000/api/billing/webhook

# Supabase Auth (Phase 23)
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_ANON_KEY="eyJ..."
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."  # server only — never expose to browser bundles
# NSR_AUTH_REQUIRED="1"             # require Bearer JWT on /api/* in production

# Apply migration: supabase/migrations/20260623120000_profiles.sql
# Apply migration: supabase/migrations/20260624120000_workspace_sync.sql

# Market is fixed to Hong Kong (hk) in src/lib/market/config.ts for this deployment.
